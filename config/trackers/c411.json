{
  "id": "c411",
  "name": "C411",
  "baseUrl": "https://c411.org",
  "enabled": true,
  "login": {
    "url": "login?redirect=/",
    "method": "POST",
    "contentType": "form",
    "body": {
      "username": "{{username}}",
      "email": "{{username}}",
      "password": "{{password}}"
    },
    "failurePatterns": [
      "type=\"password\"",
      "name=\"password\""
    ]
  },
  "fetch": {
    "url": "user/profile",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "uploadedBytes": {
        "regex": "(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))[\\s\\S]{0,260}?Envoy",
        "transform": "bytes"
      },
      "downloadedBytes": {
        "regex": "(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))[\\s\\S]{0,260}?T(?:?l?|ele|[?e]l[?e])charg",
        "transform": "bytes"
      }
    }
  },
  "dashboard": {
    "byteUnit": "decimal"
  }
}
