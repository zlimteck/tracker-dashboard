{
  "id": "nexum",
  "name": "Nexum",
  "baseUrl": "https://nexum-core.com",
  "enabled": true,
  "login": {
    "url": "login",
    "method": "POST",
    "contentType": "form",
    "body": {
      "username": "{{username}}",
      "email": "{{username}}",
      "password": "{{password}}"
    },
    "failurePatterns": [
      "type=\"password\"",
      "name=\"password\""
    ]
  },
  "fetch": {
    "url": "activity",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "uploadedBytes":   { "regex": "user-stat-up[^>]*>[\\s\\S]*?(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</span>", "transform": "bytes" },
      "downloadedBytes": { "regex": "user-stat-dn[^>]*>[\\s\\S]*?(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</span>", "transform": "bytes" },
      "seedBonus":       { "regex": "class=[\"']val[\"'][\\s\\S]{0,160}?(?<value>\\d[\\d\\s.,]*)[\\s\\S]{0,160}?Points bonus", "transform": "string" },
      "seeding":         { "regex": "Seeds\\s*\\((?<value>\\d+)\\)",                                                     "transform": "integer" }
    }
  },
  "dashboard": { "byteUnit": "binary" }
}
