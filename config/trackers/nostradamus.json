{
  "id": "nostradamus",
  "name": "Nostradamus",
  "baseUrl": "https://nostradamus.foo",
  "enabled": true,
  "ratioless": true,
  "login": {
    "url": "sign-in",
    "method": "POST",
    "contentType": "form",
    "body": {
      "password": "{{password}}"
    },
    "failurePatterns": [
      "type=\"password\"",
      "private-key-input",
      "name=\"password\"",
      "name=\"username\"",
      "Se connecter"
    ]
  },
  "fetch": {
    "url": "activity",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "uploadedBytes":   { "regex": ">\\s*Upload total\\s*<[\\s\\S]{0,400}?>\\s*(?<value>\\d[\\d.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*<",   "transform": "bytes"  },
      "downloadedBytes": { "regex": ">\\s*Download total\\s*<[\\s\\S]{0,400}?>\\s*(?<value>\\d[\\d.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*<", "transform": "bytes"  },
      "points":          { "regex": "hero-banknotes[\\s\\S]*?sidebar-account-stat__value[^>]*>\\s*(?<value>[\\d\\s.,]+)",                       "transform": "integer" },
      "rate":            { "regex": "hero-bolt[\\s\\S]*?sidebar-account-stat__value[^>]*>\\s*(?<value>[\\d\\s.,]+)",                            "transform": "number"  }
    }
  },
  "dashboard": { "byteUnit": "decimal" }
}
