{
  "id": "hdforever",
  "name": "HD-Forever",
  "baseUrl": "https://hdf.world",
  "enabled": true,
  "login": {
    "url": "login.php",
    "method": "POST",
    "contentType": "form",
    "preStep": {
      "url": "login.php",
      "extract": {},
      "includeHiddenInputs": true
    },
    "body": {
      "username": "{{username}}",
      "password": "{{password}}",
      "login": "Se connecter",
      "keeplogged": "1"
    },
    "failurePatterns": [
      "Identifiant ou mot de passe incorrect",
      "type=\"password\"",
      "href=\"login.php\"",
      "Entrer</a>"
    ]
  },
  "fetch": {
    "url": "index.php",
    "responseType": "html",
    "fields": {
      "uploadedBytes": {
        "regex": "(?:class=\"stat tooltip up\"[^>]*>|Envoy[ée]\\s*:[\\s\\S]{0,160}?)(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))",
        "transform": "bytes"
      },
      "downloadedBytes": {
        "regex": "(?:class=\"stat tooltip dl\"[^>]*>|Re[çc]u\\s*:[\\s\\S]{0,160}?)(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))",
        "transform": "bytes"
      },
      "ratio": {
        "regex": "(?:class=\"tooltip r\\d+\"[^>]*>|Ratio\\s*:[\\s\\S]{0,120}?)(?<value>\\d[\\d\\s.,]*)",
        "transform": "number"
      },
      "seedBonus": {
        "regex": "(?:action=rate[^>]+>|Magasin\\s*:[\\s\\S]{0,120}?)(?<value>\\d[\\d\\s.,]*)",
        "transform": "string"
      }
    }
  },
  "dashboard": { "byteUnit": "decimal" }
}
