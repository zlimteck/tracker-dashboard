{
  "id": "hdforever",
  "name": "HD-Forever",
  "baseUrl": "https://hdf.world",
  "enabled": true,
  "login": {
    "url": "login.php",
    "method": "POST",
    "contentType": "form",
    "preStep": {
      "url": "login.php",
      "extract": {},
      "includeHiddenInputs": true
    },
    "body": {
      "username": "{{username}}",
      "password": "{{password}}",
      "keeplogged": "1"
    },
    "failurePatterns": [
      "Identifiant ou mot de passe incorrect",
      "type=\"password\"",
      "href=\"login.php\"",
      "Entrer</a>"
    ]
  },
  "fetch": {
    "url": "index.php",
    "responseType": "html",
    "fields": {
      "uploadedBytes":   { "regex": "Envoy[ée]\\s*:[\\s\\S]{0,160}?(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))", "transform": "bytes"  },
      "downloadedBytes": { "regex": "Re[çc]u\\s*:[\\s\\S]{0,160}?(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))",    "transform": "bytes"  },
      "ratio":           { "regex": "Ratio\\s*:[\\s\\S]{0,120}?(?<value>\\d[\\d\\s.,]*)",                                   "transform": "number" },
      "seedBonus":       { "regex": "Magasin\\s*:[\\s\\S]{0,120}?(?<value>\\d[\\d\\s.,]*)",                                 "transform": "string" }
    }
  },
  "dashboard": { "byteUnit": "decimal" }
}
