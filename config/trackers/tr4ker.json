{
  "id": "tr4ker",
  "name": "TR4KER",
  "baseUrl": "https://tr4ker.net",
  "enabled": true,
  "login": {
    "url": "login",
    "method": "POST",
    "contentType": "form",
    "body": {
      "username": "{{username}}",
      "email": "{{username}}",
      "password": "{{password}}"
    },
    "failurePatterns": [
      "type=\"password\"",
      "name=\"password\"",
      "href=\"/login\"",
      "aria-label=\"Connexion\""
    ],
    "cookieOnly": true
  },
  "fetch": {
    "url": "/",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "ratio":           { "regex": "RATIO\\s*:?\\s*(?<value>[\\d\\s.,]+)",                                             "transform": "number" },
      "uploadedBytes":   { "regex": ">UPLOAD<[\\s\\S]{0,180}?_statValue[^>]*>\\s*(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*<",   "transform": "bytes" },
      "downloadedBytes": { "regex": ">DOWNLOAD<[\\s\\S]{0,180}?_statValue[^>]*>\\s*(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*<", "transform": "bytes" }
    }
  },
  "dashboard": { "byteUnit": "decimal" }
}
