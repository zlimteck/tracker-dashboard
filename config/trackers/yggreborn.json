{
  "id": "yggreborn",
  "name": "YGGReborn",
  "baseUrl": "https://www.yggreborn.org",
  "enabled": true,
  "login": {
    "url": "login?next=/account/",
    "method": "POST",
    "contentType": "form",
    "body": {
      "identifier": "{{username}}",
      "password": "{{password}}"
    },
    "failurePatterns": [
      "type=\"password\"",
      "name=\"password\"",
      "name=\"identifier\"",
      "Connexion à ton compte",
      "cf-turnstile"
    ],
    "cookieOnly": true
  },
  "fetch": {
    "url": "account/",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "uploadedBytes":   { "regex": "(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</div>[\\s\\S]{0,180}?>Upload<",   "transform": "bytes" },
      "downloadedBytes": { "regex": "(?<value>\\d[\\d\\s.,]*\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</div>[\\s\\S]{0,180}?>Download<", "transform": "bytes" }
    }
  },
  "dashboard": { "byteUnit": "decimal" }
}
