{
  "id": "tigersdl",
  "name": "Tigers-DL",
  "baseUrl": "https://www.tigers-dl.net",
  "enabled": false,
  "login": {
    "url": "account-login.php",
    "method": "POST",
    "contentType": "form",
    "body": {
      "username": "{{username}}",
      "password": "{{password}}"
    },
    "failurePatterns": [
      "account-login.php",
      "type=\"password\"",
      "type='password'",
      "name=\"password\"",
      "name='password'"
    ]
  },
  "fetch": {
    "url": "mybonus.php",
    "mode": "browser",
    "responseType": "html",
    "fields": {
      "uploadedBytes": {
        "regex": "title=['\"]Partager['\"][\\s\\S]{0,180}?<font[^>]*>\\s*(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</font>",
        "transform": "bytes"
      },
      "downloadedBytes": {
        "regex": "title=['\"][^'\"]*charg[^'\"]*['\"][\\s\\S]{0,180}?<font[^>]*>\\s*(?<value>[\\d\\s.,]+\\s*(?:[KMGTPE](?:i?B|io|o)|B|o))\\s*</font>",
        "transform": "bytes"
      },
      "seedBonus": {
        "regex": "Votre solde[\\s\\S]{0,180}?score-points[^>]*>\\s*(?<value>[\\d\\s.,]+)",
        "transform": "string"
      },
      "seeding": {
        "regex": "(?:Nombres de Torrents que vous avez en seed\\s*:\\s*|title=['\"]Seeding['\"][\\s\\S]{0,120}?<b>\\s*)(?<value>\\d+)",
        "transform": "integer"
      }
    }
  },
  "dashboard": {
    "byteUnit": "decimal"
  }
}
