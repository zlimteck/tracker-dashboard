      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(tracker_uploaded_bytes, tracker)",
        "hide": 0,
        "includeAll": true,
        "label": "Tracker",
        "multi": true,
        "name": "tracker",
        "options": [],
        "query": {
          "query": "label_values(tracker_uploaded_bytes, tracker)",
